{
  "name": "investing-widget",
  "version": "0.1.0",
  "description": "Always-on-top Windows desktop widget for real-time crypto, US stocks, and KR stocks prices",
  "main": "out/main/index.js",
  "author": "leejun51",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "tsx --tsconfig tsconfig.test.json --test test/*.test.ts",
    "package:win": "electron-vite build && electron-builder --win",
    "package:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@mathieuc/tradingview": "^3.5.2",
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.6"
  }
}
